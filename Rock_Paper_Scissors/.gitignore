# ──────────────────────────────────────────────────────────────
# .gitignore — Rock Paper Scissors
# ──────────────────────────────────────────────────────────────

# Python bytecode & caches
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Pytest cache
.pytest_cache/
.cache/
htmlcov/
.coverage
coverage.xml

# MyPy
.mypy_cache/
.dmypy.json

# IDEs
.idea/
.vscode/
*.suo
*.user

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
