# ──────────────────────────────────────────────────────────────
# .gitignore — Student Marks Predictor
# ──────────────────────────────────────────────────────────────

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Pytest / coverage
.pytest_cache/
.cache/
htmlcov/
.coverage
coverage.xml

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# MyPy
.mypy_cache/

# IDEs
.idea/
.vscode/
*.suo
*.user

# OS
.DS_Store
Thumbs.db
desktop.ini

# ── Project-specific ──────────────────────────────────────────
# Trained models — optionally commit small models
# models/*.pkl

# Generated visualizations
*.png
*.jpg
*.pdf

# Logs
*.log
